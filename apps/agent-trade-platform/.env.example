# Omit or false = talk to Go AXL HTTP APIs (/topology, /recv, /send). Set true only for UI-only demos.
# DEMO_MODE=

AGENT_ALICE_API=http://127.0.0.1:9002
AGENT_BOB_API=http://127.0.0.1:9012

# Receipt of `origin:'human'` AXL payloads on a node's inbox runs 0G on that respondent and sends back with `origin:'auto'` (breaking infinite loops).
AXL_AUTO_REPLY=true

# ─── Inference (pick ONE backend)
#
# A) Integrate Network / OpenAI-compatible router — set API key + base URL (+ optional model).
#    Requests go to {ZERO_G_ROUTER_BASE_URL}/chat/completions — set the OpenAI root ending with /v1 per docs (often …/openapi/v1).
# ZERO_G_CHAT_BACKEND omitted or "router": use router when API key + base URL are present.
#
0G_API_KEY=
ZERO_G_ROUTER_BASE_URL=
# Optional aliases: ZERO_G_ROUTER_API_KEY, 0G_ROUTER_BASE_URL
ZERO_G_ROUTER_MODEL=qwen/qwen-2.5-7b-instruct

# Force backend: unset | router | broker
# ZERO_G_CHAT_BACKEND=

# B) 0G decentralized serving broker — wallet settles fees (processResponse).
ZERO_G_RPC_URL=https://evmrpc-testnet.0g.ai
ALICE_PRIVATE_KEY=
BOB_PRIVATE_KEY=
ALICE_PROVIDER_ADDRESS=
BOB_PROVIDER_ADDRESS=
# PRIVATE_KEY=
# PROVIDER_ADDRESS=

BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
BASE_RPC_URL=https://mainnet.base.org
UNICHAIN_SEPOLIA_RPC_URL=https://sepolia.unichain.org

UNISWAP_API_KEY=

# Token registry for NL quote parsing (JSON). Example:
# TOKEN_REGISTRY_JSON={"84532":[{"symbol":"USDC","address":"0x...","decimals":6}],"1301":[{"symbol":"USDC","address":"0x...","decimals":6}]}
# TOKEN_REGISTRY_JSON=

PORT=8787
