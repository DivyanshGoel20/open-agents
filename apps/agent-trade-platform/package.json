{
  "name": "agent-trade-platform",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"wait-on tcp:127.0.0.1:8787 && npm run dev:web\"",
    "dev:web": "vite",
    "dev:server": "tsx watch server/index.ts",
    "build": "tsc -p tsconfig.server.json && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@0glabs/0g-serving-broker": "^0.6.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "ethers": "6.13.1",
    "express": "^4.21.2",
    "openai": "^4.104.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "viem": "^2.28.4"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "tsx": "^4.19.2",
    "wait-on": "^8.0.3",
    "typescript": "^5.7.3",
    "vite": "^6.0.7"
  },
  "engines": {
    "node": ">=22"
  }
